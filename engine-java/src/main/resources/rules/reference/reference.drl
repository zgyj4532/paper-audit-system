// Rule 10: Monograph [M] Format Check - Missing Place of Publication: Publisher
rule "Monograph Reference Missing Place of Publication and Publisher Check"
when 
    $ref: Reference(rawText.contains("[M]") && !rawText.matches(".*[\\u4e00-\\u9fff\\w]+\\s*:\\s*[\\u4e00-\\u9fff\\w]+.*"))
then
    String rawText = $ref.getRawText();
    int refNum = 0;
    try {
        String refId = $ref.getRefId();
        if (refId != null && !refId.isEmpty()) {
            String cleaned = refId.replaceAll("\\[|\\]", "").trim();
            refNum = Integer.parseInt(cleaned);
        }
    } catch (Exception e) {
        logger.warn("Unable to parse reference number");
    }
    
    if (refNum > 0) {
        logger.debug("DEBUG: Monograph reference [{}] missing place of publication and publisher", refNum);
        results.add(Issue.newBuilder()
                .setCode("ERR_REF_MONO_NO_PUBLISHER")
                .setMessage("参考文献 [" + refNum + "] 专著格式错误：缺少出版地和出版者信息")
                .setSectionId(0)
                .setSeverity(Severity.MEDIUM)
                .setSuggestion("请补充出版地和出版者信息，格式如 北京: 出版者")
                .setOriginalSnippet(rawText.length() > 150 ? rawText.substring(0, 150) + "..." : rawText)
                .build());
    }
end

