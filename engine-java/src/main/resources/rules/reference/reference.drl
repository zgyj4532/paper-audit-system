        logger.warn("Unable to parse reference number");
    }
    
    if (refNum > 0) {
        logger.debug("DEBUG: Journal reference [{}] uses lowercase [j]", refNum);
        results.add(Issue.newBuilder()
                .setCode("ERR_REF_JOURNAL_LOWERCASE")
                .setMessage("参考文献 [" + refNum + "] 期刊标识错误：应使用大写 [J]，而不是小写 [j]")
                .setSectionId(0)
                .setSeverity(Severity.MEDIUM)
                .setSuggestion("请将小写期刊标识改为大写期刊标识")
                .setOriginalSnippet(rawText.length() > 150 ? rawText.substring(0, 150) + "..." : rawText)
                .build());
    }
end


// Rule 16: Journal [J] Format Check - Year is Two Digits (after comma)
rule "Journal Reference Two-Digit Year Check"
when 
    $ref: Reference(rawText.contains("[J]"))
then
    String rawText = $ref.getRawText();
    int refNum = 0;
    try {
        String refId = $ref.getRefId();
        if (refId != null && !refId.isEmpty()) {
            String cleaned = refId.replaceAll("\\[|\\]", "").trim();
            refNum = Integer.parseInt(cleaned);
        }
    } catch (Exception e) {
        logger.warn("Unable to parse reference number");
    }
    
    if (refNum > 0) {
        String window = rawText;
        int typeIndex = rawText.indexOf("[J]");
        if (typeIndex >= 0) {
            window = rawText.substring(typeIndex + 3);
        }
        int doiIndex = window.toUpperCase().indexOf("DOI");
        if (doiIndex >= 0) {
            window = window.substring(0, doiIndex);
        }

        Matcher matcher = Pattern.compile("(?<!\\d)(?:,|，|\\.)\\s*(\\d{2})(?=\\s*(?:,|，|\\.|$))").matcher(window);
        if (matcher.find()) {
            String twoDigit = matcher.group(1);
            logger.debug("DEBUG: Journal reference [{}] year is two digits", refNum);
            results.add(Issue.newBuilder()
                    .setCode("ERR_REF_JOURNAL_YEAR_TWO_DIGIT")
                    .setMessage("参考文献 [" + refNum + "] 年份格式错误：年份应为四位数字，而不是两位数字")
                    .setSectionId(0)
                    .setSeverity(Severity.MEDIUM)
                    .setSuggestion("请将两位年份改为四位年份")
                    .setOriginalSnippet(rawText.length() > 150 ? rawText.substring(0, 150) + "..." : rawText)
                    .build());
        }
    }
end

// Rule 17: Monograph [M] Format Check - Year is Two Digits (after comma)
rule "Monograph Reference Year Two-Digit Check"
when 
    $ref: Reference(rawText.contains("[M]"))
then
    String rawText = $ref.getRawText();
    int refNum = 0;
    try {
        String refId = $ref.getRefId();
        if (refId != null && !refId.isEmpty()) {
            String cleaned = refId.replaceAll("\\[|\\]", "").trim();
            refNum = Integer.parseInt(cleaned);
        }
    } catch (Exception e) {
        logger.warn("Unable to parse reference number");
    }
    
    if (refNum > 0) {
        String window = rawText;
        int typeIndex = rawText.indexOf("[M]");
        if (typeIndex >= 0) {
            window = rawText.substring(typeIndex + 3);
        }
        int doiIndex = window.toUpperCase().indexOf("DOI");
        if (doiIndex >= 0) {
            window = window.substring(0, doiIndex);
        }

        Matcher matcher = Pattern.compile("(?<!\\d)(?:,|，|\\.)\\s*(\\d{2})(?=\\s*(?:,|，|\\.|$))").matcher(window);
        if (matcher.find()) {
            String twoDigit = matcher.group(1);
            try {
                Integer.parseInt(twoDigit);
                logger.debug("DEBUG: Monograph reference [{}] year is two digits {}", refNum, twoDigit);
                results.add(Issue.newBuilder()
                        .setCode("ERR_REF_MONO_YEAR_TWO_DIGIT")
                        .setMessage("参考文献 [" + refNum + "] 年份格式错误：年份应为四位数字，而不是两位数字 " + twoDigit)
                        .setSectionId(0)
                        .setSeverity(Severity.MEDIUM)
                        .setSuggestion("请将两位年份改为四位年份")
                        .setOriginalSnippet(rawText.length() > 150 ? rawText.substring(0, 150) + "..." : rawText)
                        .build());
            } catch (NumberFormatException e) {
                logger.warn("Unable to parse year");
            }
        }
    }
end

// Rule 18: Journal [J] Format Check - Missing Author
rule "Journal Reference Missing Author Check"
when 
    $ref: Reference(rawText.contains("[J]"))
then
    String rawText = $ref.getRawText();
    int refNum = 0;
    try {
        String refId = $ref.getRefId();
        if (refId != null && !refId.isEmpty()) {
            String cleaned = refId.replaceAll("\\[|\\]", "").trim();
            refNum = Integer.parseInt(cleaned);
        }
    } catch (Exception e) {
        logger.warn("Unable to parse reference number");
    }
    
    if (refNum > 0) {
        int typeIndex = rawText.indexOf("[J]");
        if (refNum > 0) {
            String beforeType = rawText.substring(0, typeIndex);
            if (!beforeType.contains(".") || beforeType.trim().length() < 3) {
                logger.debug("DEBUG: Journal reference [{}] missing author", refNum);
                results.add(Issue.newBuilder()
                        .setCode("ERR_REF_JOURNAL_NO_AUTHOR")
                        .setMessage("参考文献 [" + refNum + "] 期刊格式错误：缺少作者信息")
                        .setSectionId(0)
                        .setSeverity(Severity.HIGH)
                        .setSuggestion("请补充作者信息，格式如：作者. 题名. 期刊名, 年份.")
                        .setOriginalSnippet(rawText.length() > 150 ? rawText.substring(0, 150) + "..." : rawText)
                        .build());
            }
        }
    }
end

