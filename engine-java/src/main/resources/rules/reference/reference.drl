// ==================== New Rules: Check Required Fields ====================

// Rule 21: Monograph [M] - Missing Place of Publication
rule "Monograph Reference Missing Place of Publication Check"
when 
    $ref: Reference(rawText.contains("[M]") && !rawText.matches(".*[：:].*"))
then
    String rawText = $ref.getRawText();
    int refNum = 0;
    try {
        String refId = $ref.getRefId();
        if (refId != null && !refId.isEmpty()) {
            String cleaned = refId.replaceAll("\\[|\\]", "").trim();
            refNum = Integer.parseInt(cleaned);
        }
    } catch (Exception e) {
        logger.warn("Unable to parse reference number");
    }
    
    if (refNum > 0) {
        logger.debug("DEBUG: Monograph reference [{}] missing place of publication", refNum);
        results.add(Issue.newBuilder()
                .setCode("ERR_REF_MONO_NO_PLACE")
                .setMessage("参考文献 [" + refNum + "] 专著格式错误：缺少出版地")
                .setSectionId(0)
                .setSeverity(Severity.HIGH)
                .setSuggestion("请补充出版地信息，格式如：出版地: 出版者")
