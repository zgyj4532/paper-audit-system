// Rule 12: Citation Consistency Check - Missing References
rule "Check Missing References"
when 
    $data: ParsedData()
then
    Set<Integer> citedNumbers = new HashSet<>();
    Set<Integer> existingRefNumbers = new HashSet<>();
    
    // Extract all citations in the main text
    for (Section section : $data.getSectionsList()) {
        Pattern citationPattern = Pattern.compile("\\[(\\d+)\\]");
        Matcher matcher = citationPattern.matcher(section.getText());
        while (matcher.find()) {
            try {
                citedNumbers.add(Integer.parseInt(matcher.group(1)));
            } catch (NumberFormatException e) {
                logger.warn("Unable to parse citation number");
            }
        }
    }
    
    // Extract all numbers in the reference list
    for (Reference ref : $data.getReferencesList()) {
        String refId = ref.getRefId();
        if (refId != null && !refId.isEmpty()) {
            try {
                String cleaned = refId.replaceAll("\\[|\\]", "").trim();
                existingRefNumbers.add(Integer.parseInt(cleaned));
            } catch (NumberFormatException e) {
                logger.warn("Unable to parse reference number");
            }
        }
    }
    
    // Check for missing citations
    for (Integer citedNum : citedNumbers) {
        if (!existingRefNumbers.contains(citedNum)) {
            logger.debug("DEBUG: Missing reference detected [{}]", citedNum);
            results.add(Issue.newBuilder()
                    .setCode("ERR_REF_MISSING")
                    .setMessage("正文中的引用 [" + citedNum + "] 已被引用，但未出现在参考文献表中")
                    .setSectionId(0)
                    .setSeverity(Severity.CRITICAL)
                    .setSuggestion("请补充参考文献 [" + citedNum + "]")
                    .setOriginalSnippet("Citation [" + citedNum + "]")
                    .build());
        }
    }

    for (Integer refNum : existingRefNumbers) {
        if (!citedNumbers.contains(refNum)) {
            logger.debug("DEBUG: Found unused reference [{}]", refNum);
            results.add(Issue.newBuilder()
                    .setCode("WARN_REF_UNUSED")
                    .setMessage("参考文献 [" + refNum + "] 未在正文中被引用")
                    .setSectionId(0)
                    .setSeverity(Severity.LOW)
                    .setSuggestion("请删除未使用的参考文献，或在正文中补充引用")
                    .setOriginalSnippet("")
                    .build());
        }
    }
end

// Rule 13: Journal [J] Format Check - Year Too Early
rule "Journal Reference Year Too Early Check"
when 
    $ref: Reference(rawText.contains("[J]"))
then
    String rawText = $ref.getRawText();
    int refNum = 0;
    try {
        String refId = $ref.getRefId();
        if (refId != null && !refId.isEmpty()) {
            String cleaned = refId.replaceAll("\\[|\\]", "").trim();
            refNum = Integer.parseInt(cleaned);
        }
    } catch (Exception e) {
        logger.warn("Unable to parse reference number");
    }
    
    if (refNum > 0) {
        String window = rawText;
        int typeIndex = rawText.indexOf("[J]");
        if (typeIndex >= 0) {
            window = rawText.substring(typeIndex + 3);
        }
        int doiIndex = window.toUpperCase().indexOf("DOI");
        if (doiIndex >= 0) {
            window = window.substring(0, doiIndex);
        }

        Matcher yearMatcher = Pattern.compile("(?<!\\d)(\\d{4})(?!\\d)").matcher(window);
        if (yearMatcher.find()) {
            try {
                int year = Integer.parseInt(yearMatcher.group(1));

                if (year < 1900) {
                    logger.debug("DEBUG: Journal reference [{}] year {} < 1900", refNum, year);
                    results.add(Issue.newBuilder()
                            .setCode("ERR_REF_JOURNAL_YEAR_EARLY")
                            .setMessage("参考文献 [" + refNum + "] 年份过早：" + year + " < 1900")
                            .setSectionId(0)
                            .setSeverity(Severity.MEDIUM)
                            .setSuggestion("请检查年份是否正确")
                            .setOriginalSnippet(rawText.length() > 150 ? rawText.substring(0, 150) + "..." : rawText)
                            .build());
                }
            } catch (NumberFormatException e) {
                logger.warn("Unable to parse year");
            }
        }
    }
end

