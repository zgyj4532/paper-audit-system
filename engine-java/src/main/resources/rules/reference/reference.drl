package rules.reference

import com.auditor.grpc.*
import java.util.regex.Pattern
import java.util.regex.Matcher
import java.util.*

global java.util.List results
global org.slf4j.Logger logger

dialect "java"

// ==================== Rule Definitions ====================

// Rule 1: Journal [J] Format Check - Full-width Comma Check
rule "Journal Reference Full-width Comma Check"
when 
    $ref: Reference(rawText.contains("[J]") && rawText.contains("，"))
then
    String rawText = $ref.getRawText();
    int refNum = 0;
    try {
        String refId = $ref.getRefId();
        if (refId != null && !refId.isEmpty()) {
            String cleaned = refId.replaceAll("\\[|\\]", "").trim();
            refNum = Integer.parseInt(cleaned);
        }
    } catch (Exception e) {
        logger.warn("Unable to parse reference number");
    }
    
    if (refNum > 0) {
        logger.debug("DEBUG: Journal reference [{}] detected full-width comma", refNum);
        results.add(Issue.newBuilder()
                .setCode("ERR_REF_JOURNAL_FULL_COMMA")
                .setMessage("参考文献 [" + refNum + "] 期刊格式错误：使用了中文逗号，应使用英文逗号")
                .setSectionId(0)
                .setSeverity(Severity.HIGH)
                .setSuggestion("请将中文逗号（，）替换为英文逗号（,）")
                .setOriginalSnippet(rawText.length() > 150 ? rawText.substring(0, 150) + "..." : rawText)
                .build());
    }
end

// Rule 2: Journal [J] Format Check - Year Out of Range
rule "Journal Reference Year Out of Range Check"
when 
    $ref: Reference(rawText.contains("[J]"))
then
    String rawText = $ref.getRawText();
    int refNum = 0;
    try {
        String refId = $ref.getRefId();
        if (refId != null && !refId.isEmpty()) {
            String cleaned = refId.replaceAll("\\[|\\]", "").trim();
            refNum = Integer.parseInt(cleaned);
        }
    } catch (Exception e) {
        logger.warn("Unable to parse reference number");
    }
    
    if (refNum > 0) {
        String window = rawText;
        int typeIndex = rawText.indexOf("[J]");
        if (typeIndex >= 0) {
            window = rawText.substring(typeIndex + 3);
        }
        int doiIndex = window.toUpperCase().indexOf("DOI");
        if (doiIndex >= 0) {
            window = window.substring(0, doiIndex);
        }
        Integer year = null;
        Matcher yearMatcher = Pattern.compile("(?<!\\d)(\\d{4})(?!\\d)").matcher(window);
        if (yearMatcher.find()) {
            try {
                year = Integer.parseInt(yearMatcher.group(1));
            } catch (NumberFormatException e) {
                logger.warn("Unable to parse publication year");
            }
        }
        int currentYear = 2026;

        if (year != null && year > currentYear) {
            logger.debug("DEBUG: Journal reference [{}] year {} > {}", refNum, year, currentYear);
            results.add(Issue.newBuilder()
                    .setCode("ERR_REF_JOURNAL_YEAR_EXCEED")
                    .setMessage("参考文献 [" + refNum + "] 年份超出范围：" + year + " > " + currentYear)
                    .setSectionId(0)
                    .setSeverity(Severity.HIGH)
                    .setSuggestion("请检查年份是否正确")
                    .setOriginalSnippet(rawText.length() > 150 ? rawText.substring(0, 150) + "..." : rawText)
                    .build());
        }
    }
end

// Rule 3: Journal [J] Format Check - No Dot After [J]
rule "Journal Reference J Mark No Dot Check"
when 
    $ref: Reference(rawText.contains("[J]") && !rawText.contains("[J]."))
then
    String rawText = $ref.getRawText();
    int refNum = 0;
    try {
        String refId = $ref.getRefId();
        if (refId != null && !refId.isEmpty()) {
            String cleaned = refId.replaceAll("\\[|\\]", "").trim();
            refNum = Integer.parseInt(cleaned);
        }
    } catch (Exception e) {
        logger.warn("Unable to parse reference number");
    }
    
    if (refNum > 0) {
        logger.debug("DEBUG: Journal reference [{}] no dot after [J]", refNum);
        results.add(Issue.newBuilder()
                .setCode("ERR_REF_JOURNAL_NO_DOT")
                .setMessage("参考文献 [" + refNum + "] 期刊格式错误：[J] 后应有英文句号")
                .setSectionId(0)
                .setSeverity(Severity.HIGH)
                .setSuggestion("请在期刊标识后添加英文句号")
                .setOriginalSnippet(rawText.length() > 150 ? rawText.substring(0, 150) + "..." : rawText)
                .build());
    }
end

// Rule 4: Journal [J] Format Check - Missing Volume(Issue)
rule "Journal Reference Missing Volume and Issue Check"
when 
    $ref: Reference(rawText.contains("[J]") && !rawText.matches(".*\\d+\\s*\\(\\s*\\d+\\s*\\).*"))
then
    String rawText = $ref.getRawText();
    int refNum = 0;
    try {
        String refId = $ref.getRefId();
        if (refId != null && !refId.isEmpty()) {
            String cleaned = refId.replaceAll("\\[|\\]", "").trim();
            refNum = Integer.parseInt(cleaned);
        }
    } catch (Exception e) {
        logger.warn("Unable to parse reference number");
    }
    
    if (refNum > 0) {
        logger.debug("DEBUG: Journal reference [{}] missing volume(issue)", refNum);
        results.add(Issue.newBuilder()
                .setCode("ERR_REF_JOURNAL_NO_VOLUME")
                .setMessage("参考文献 [" + refNum + "] 期刊格式错误：缺少卷(期)信息")
                .setSectionId(0)
                .setSeverity(Severity.MEDIUM)
                .setSuggestion("请补充卷(期)信息，格式如 10(2)")
                .setOriginalSnippet(rawText.length() > 150 ? rawText.substring(0, 150) + "..." : rawText)
                .build());
    }
end

// Rule 5: Journal [J] Format Check - Missing Page
rule "Journal Reference Missing Page Check"
when 
    $ref: Reference(rawText.contains("[J]") && !rawText.matches(".*:\\s*\\d+\\s*[-~]?\\s*\\d*.*"))
then
    String rawText = $ref.getRawText();
    int refNum = 0;
    try {
        String refId = $ref.getRefId();
        if (refId != null && !refId.isEmpty()) {
            String cleaned = refId.replaceAll("\\[|\\]", "").trim();
            refNum = Integer.parseInt(cleaned);
        }
    } catch (Exception e) {
        logger.warn("Unable to parse reference number");
    }
    
    if (refNum > 0) {
        logger.debug("DEBUG: Journal reference [{}] missing page", refNum);
        results.add(Issue.newBuilder()
                .setCode("ERR_REF_JOURNAL_NO_PAGE")
                .setMessage("参考文献 [" + refNum + "] 期刊格式错误：缺少页码信息")
                .setSectionId(0)
                .setSeverity(Severity.MEDIUM)
                .setSuggestion("请补充页码信息，格式如 1-10")
                .setOriginalSnippet(rawText.length() > 150 ? rawText.substring(0, 150) + "..." : rawText)
                .build());
    }
end

// Rule 6: Journal [J] Format Check - Multiple Authors but No "et al."
rule "Journal Reference Multiple Authors No Et Al. Check"
when 
    $ref: Reference(rawText.contains("[J]"))
then
    String rawText = $ref.getRawText();
    int refNum = 0;
    try {
        String refId = $ref.getRefId();
        if (refId != null && !refId.isEmpty()) {
            String cleaned = refId.replaceAll("\\[|\\]", "").trim();
            refNum = Integer.parseInt(cleaned);
        }
    } catch (Exception e) {
        logger.warn("Unable to parse reference number");
    }
    
    if (refNum > 0) {
        int typeIndex = rawText.indexOf("[J]");
        if (typeIndex > 0) {
            String authorPart = rawText.substring(0, typeIndex);
            int commaCount = 0;
            for (char c : authorPart.toCharArray()) {
                if (c == ',') {
                    commaCount++;
                }
            }

            if (commaCount > 2) {
                if (!authorPart.contains("等") && !authorPart.contains("et al.") &&
                        !authorPart.contains("et al") && !authorPart.contains("等.")) {
                    logger.debug("DEBUG: Journal reference [{}] multiple authors but no et al.", refNum);
                    results.add(Issue.newBuilder()
                            .setCode("ERR_REF_JOURNAL_MULTI_AUTHOR")
                            .setMessage("参考文献 [" + refNum + "] 多作者格式错误：超过 2 位作者应使用“等”")
                            .setSectionId(0)
                            .setSeverity(Severity.MEDIUM)
                            .setSuggestion("请在第二位作者后添加“等”")
                            .setOriginalSnippet(rawText.length() > 150 ? rawText.substring(0, 150) + "..." : rawText)
                            .build());
                }
            }
        }
    }
end
