                .setMessage("参考文献 [" + refNum + "] 专著格式错误：使用了中文句号，应使用英文句号")
                .setSectionId(0)
                .setSeverity(Severity.HIGH)
                .setSuggestion("请将中文句号（。）替换为英文句号（.）")
                .setOriginalSnippet(rawText.length() > 150 ? rawText.substring(0, 150) + "..." : rawText)
                .build());
    }
end

