// Rule 15: Journal [J] Format Check - Lowercase [j]
rule "Journal Reference Lowercase j Check"
when 
    $ref: Reference(rawText.contains("[j]"))
then
    String rawText = $ref.getRawText();
    int refNum = 0;
    try {
        String refId = $ref.getRefId();
        if (refId != null && !refId.isEmpty()) {
