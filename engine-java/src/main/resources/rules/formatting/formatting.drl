// Rule 10: Level 3 Heading Font Size Check (should be 14pt)
rule "Level 3 Heading Font Size Check"
when
    $section: Section(level == 3, type == "heading")
then
    String fontSize = (String)$section.getPropsMap().get("font-size");
    if (fontSize != null && !fontSize.isEmpty()) {
        try {
            double size = Double.parseDouble(fontSize.replaceAll("[^0-9.]", ""));
            if (Math.abs(size - 14) > 1) {
                results.add(createFormatIssue(
                    "FMT_HEADING_SIZE_003",
                    "Section " + $section.getSectionId() + " level 3 heading font size should be 14pt, current is " + size + "pt",
