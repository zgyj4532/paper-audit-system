package rules.formatting

import com.auditor.grpc.Issue
import com.auditor.grpc.Severity
import com.auditor.grpc.Section
import com.auditor.grpc.ParsedData
import org.slf4j.Logger
import java.util.*

global java.util.List results
global Logger logger

// ==================== Helper Functions ====================

function Issue createFormatIssue(String code, String message, int sectionId, Severity severity, String suggestion) {
    return Issue.newBuilder()
        .setCode(code)
        .setMessage(message)
        .setSectionId(sectionId)
        .setSeverity(severity)
        .setSuggestion(suggestion)
        .setOriginalSnippet("")
        .build();
}

// ==================== Rule Definitions ====================

// Rule 1: Precise Line Spacing Check (1.5 ± 0.05)
rule "Precise Line Spacing Check"
when
    $section: Section(type == "paragraph" || type == "heading")
then
    String lineHeightStr = (String)$section.getPropsMap().get("line-height");
    if (lineHeightStr != null && !lineHeightStr.isEmpty()) {
        try {
            double lineHeight = Double.parseDouble(lineHeightStr);
            
            if (Math.abs(lineHeight - 1.5) > 0.05) {
                results.add(createFormatIssue(
                    "FMT_LINE_HEIGHT_001",
                    "Section " + $section.getSectionId() + " line spacing does not meet the standard: " + lineHeight + ", should be 1.5 (tolerance ±0.05)",
                    (int)$section.getSectionId(),
                    Severity.MEDIUM,
                    "Please adjust the line spacing to 1.5 times"
                ));
            }
        } catch (NumberFormatException e) {
            logger.warn("Unable to parse line spacing value: {}", lineHeightStr);
        }
    }
end

// Rule 2: Hierarchy Check - Heading Sequence Verification
rule "Heading Sequence Hierarchy Check"
when
    $data: ParsedData()
then
    List<Section> sections = new ArrayList<>($data.getSectionsList());
    
    for (int i = 0; i < sections.size() - 1; i++) {
        Section current = sections.get(i);
        Section next = sections.get(i + 1);
        
        if ("heading".equals(current.getType()) && "heading".equals(next.getType())) {
            int currentLevel = current.getLevel();
            int nextLevel = next.getLevel();
            
            // Check if hierarchy is reasonable (no skipping levels)
            if (nextLevel > currentLevel + 1) {
                results.add(createFormatIssue(
                    "FMT_HEADING_LEVEL_JUMP",
                    "Section " + next.getSectionId() + " heading level jump: from level " + currentLevel + " to level " + nextLevel,
                    (int)next.getSectionId(),
                    Severity.HIGH,
                    "Please use heading levels in order"
                ));
            }
            
            // Check for reverse order (e.g., level 2 followed directly by level 1, unless it's a new chapter)
            if (nextLevel < currentLevel && nextLevel != 1) {
                results.add(createFormatIssue(
                    "FMT_HEADING_LEVEL_REVERSE",
                    "Section " + next.getSectionId() + " heading level reverse order: from level " + currentLevel + " down to level " + nextLevel,
                    (int)next.getSectionId(),
                    Severity.MEDIUM,
                    "Please check the heading level order"
                ));
            }
        }
    }
end

// Rule 3: Table Page Break Check
rule "Table Page Break Check"
when
    $section: Section(type == "table")
then
    String pageBreak = (String)$section.getPropsMap().get("page-break");
    String continueTableFlag = (String)$section.getPropsMap().get("continue-table-flag");
    
    if ("true".equals(pageBreak)) {
        if (!"true".equals(continueTableFlag)) {
            results.add(createFormatIssue(
                "FMT_TABLE_PAGE_BREAK",
                "Section " + $section.getSectionId() + " table breaks across pages but 'continue table' flag is not set",
                (int)$section.getSectionId(),
                Severity.MEDIUM,
                "Please set the 'continue table' flag or adjust the table position"
            ));
        }
    }
end

// Rule 4: Formula Alignment Check
rule "Formula Alignment Check"
when
    $section: Section(type == "formula")
then
    String alignment = (String)$section.getPropsMap().get("alignment");
    
    if (alignment == null || !alignment.equals("right")) {
        results.add(createFormatIssue(
            "FMT_FORMULA_ALIGNMENT",
            "Section " + $section.getSectionId() + " formula is not right-aligned, current alignment: " + (alignment == null ? "not set" : alignment),
            (int)$section.getSectionId(),
            Severity.MEDIUM,
            "Please set the formula alignment to right"
        ));
    }
end

// Rule 5: Level 1 Heading Font Check
rule "Level 1 Heading Font Check"
when
    $section: Section(level == 1, type == "heading")
then
    String fontFamily = (String)$section.getPropsMap().get("font-family");
    if (fontFamily == null || !fontFamily.contains("黑体")) {
        results.add(createFormatIssue(
            "FMT_HEADING_FONT_001",
            "Section " + $section.getSectionId() + " level 1 heading must use Heiti font",
            (int)$section.getSectionId(),
            Severity.MEDIUM,
            "Please change the level 1 heading font to Heiti"
        ));
    }
end

// Rule 6: Level 1 Heading Font Size Check (should be 18pt)
rule "Level 1 Heading Font Size Check"
when
    $section: Section(level == 1, type == "heading")
then
    String fontSize = (String)$section.getPropsMap().get("font-size");
    if (fontSize != null && !fontSize.isEmpty()) {
        try {
            double size = Double.parseDouble(fontSize.replaceAll("[^0-9.]", ""));
            if (Math.abs(size - 18) > 1) {
                results.add(createFormatIssue(
                    "FMT_HEADING_SIZE_001",
                    "Section " + $section.getSectionId() + " level 1 heading font size should be 18pt, current is " + size + "pt",
                    (int)$section.getSectionId(),
                    Severity.MEDIUM,
                    "Please change the level 1 heading font size to 18pt"
                ));
            }
        } catch (NumberFormatException e) {
            logger.warn("Unable to parse font size: {}", fontSize);
        }
    }
end

// Rule 7: Level 2 Heading Font Check
rule "Level 2 Heading Font Check"
when
    $section: Section(level == 2, type == "heading")
then
    String fontFamily = (String)$section.getPropsMap().get("font-family");
    if (fontFamily == null || !fontFamily.contains("黑体")) {
        results.add(createFormatIssue(
            "FMT_HEADING_FONT_002",
            "Section " + $section.getSectionId() + " level 2 heading must use Heiti font",
            (int)$section.getSectionId(),
            Severity.MEDIUM,
            "Please change the level 2 heading font to Heiti"
        ));
    }
end

// Rule 8: Level 2 Heading Font Size Check (should be 16pt)
rule "Level 2 Heading Font Size Check"
when
    $section: Section(level == 2, type == "heading")
then
    String fontSize = (String)$section.getPropsMap().get("font-size");
    if (fontSize != null && !fontSize.isEmpty()) {
        try {
            double size = Double.parseDouble(fontSize.replaceAll("[^0-9.]", ""));
            if (Math.abs(size - 16) > 1) {
                results.add(createFormatIssue(
                    "FMT_HEADING_SIZE_002",
                    "Section " + $section.getSectionId() + " level 2 heading font size should be 16pt, current is " + size + "pt",
                    (int)$section.getSectionId(),
                    Severity.MEDIUM,
                    "Please change the level 2 heading font size to 16pt"
                ));
            }
        } catch (NumberFormatException e) {
            logger.warn("Unable to parse font size: {}", fontSize);
        }
    }
end

