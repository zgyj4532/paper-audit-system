package rules.integrity
import com.auditor.grpc.*
import org.slf4j.Logger
import java.util.List
import java.util.ArrayList
import java.util.HashSet
import java.util.Set
import java.util.Arrays
global java.util.List results
global Logger logger
// Helper function: Create integrity check Issue
function Issue createIntegrityIssue(String code, String message, int sectionId, String suggestion, String originalSnippet) {
    String snippet = (originalSnippet != null && originalSnippet.length() > 100) ? originalSnippet.substring(0, 100) + "..." : (originalSnippet != null ? originalSnippet : "");
    return Issue.newBuilder().setCode(code).setMessage(message).setSectionId(sectionId)
        .setSeverity(Severity.MEDIUM).setSuggestion(suggestion).setOriginalSnippet(snippet).build();
}
// Helper function: Create error Issue
function Issue createErrorIssue(String code, String message, int sectionId, Severity severity) {
    return Issue.newBuilder().setCode(code).setMessage(message).setSectionId(sectionId)
        .setSeverity(severity).setSuggestion("请检查文档或联系管理员").setOriginalSnippet("").build();
}
// Helper function: Convert integer to Chinese numeral (must be defined BEFORE Rule 1 to avoid forward-reference compile error)
function String toChineseNum(int n) {
    String[] nums = {"\u96f6","\u4e00","\u4e8c","\u4e09","\u56db","\u4e94","\u516d","\u4e03","\u516b","\u4e5d","\u5341"};
    if (n >= 0 && n <= 10) return nums[n];
    return String.valueOf(n);
}
// Rule 1: Check section numbering continuity -> ERR_INT_SECTION_NUM_001
rule "Check section numbering continuity"
when
    $data: ParsedData()
then
    List<Section> sections = new ArrayList<>($data.getSectionsList());
    int expectedNum = 1;
    boolean triggered = false;
    for (Section section : sections) {
        if ("heading".equals(section.getType()) && section.getLevel() == 1 && !triggered) {
            String text = section.getText();
            // Extract leading number from heading text e.g. "第一章" or "1 " or "1."
            boolean matchesExpected = text.contains(String.valueOf(expectedNum)) ||
                text.contains(toChineseNum(expectedNum));
            // Fix: removed "expectedNum > 1" guard so that chapter 1 starting at wrong number is also caught
            if (!matchesExpected) {
                Issue issue = createIntegrityIssue(
                    "ERR_INT_SECTION_NUM_001",
                    "Section numbering is not continuous, expected chapter " + expectedNum + " but got: " + text,
                    section.getSectionId(),
                    "Renumber sections in order",
                    text
                );
                results.add(issue);
                triggered = true;
                break;
            }
            expectedNum++;
        }
    }
    logger.debug("Section numbering continuity check completed");
end
// Rule 2: Check heading hierarchy structure -> HIER_INT_HEADING_STRUCT_001
rule "Check heading hierarchy structure"
when
    $data: ParsedData()
then
    List<Section> sections = new ArrayList<>($data.getSectionsList());
    int lastLevel = 0;
    for (Section section : sections) {
        if ("heading".equals(section.getType())) {
            int currentLevel = section.getLevel();
            if (lastLevel > 0 && currentLevel > lastLevel + 1) {
                Issue issue = createIntegrityIssue(
                    "HIER_INT_HEADING_STRUCT_001",
                    "Heading level jump: from level " + lastLevel + " to level " + currentLevel,
                    section.getSectionId(),
                    "Heading levels should increase stepwise",
                    section.getText()
                );
                results.add(issue);
            }
            lastLevel = currentLevel;
        }
    }
    logger.debug("Heading hierarchy structure check completed");
end
// Rule 3: Check required sections -> REQ_INT_MISSING_SECTION_001 (CRITICAL)
rule "Check required sections"
when
    $data: ParsedData()
then
    // Check if abstract exists (either Chinese 摘要 or English abstract)
    boolean hasAbstract = false;
    for (Section section : $data.getSectionsList()) {
        String text = section.getText();
        if (text != null) {
            String lower = text.toLowerCase();
            if (lower.contains("\u6458\u8981") || lower.contains("abstract")) {
                hasAbstract = true;
                break;
            }
        }
    }
    if (!hasAbstract) {
        Issue issue = Issue.newBuilder()
            .setCode("REQ_INT_MISSING_SECTION_001")
            .setMessage("Missing required section: \u6458\u8981/abstract")
            .setSectionId(0)
            .setSeverity(Severity.CRITICAL)
            .setSuggestion("请在文档中补充摘要部分（摘要）")
            .setOriginalSnippet("")
            .build();
        results.add(issue);
    }
    logger.debug("Required sections check completed");
end
// Rule 4: Check figure/table/image numbering continuity -> ERR_INT_FIGURE_NUM_SKIP
// Supports: image, figure, table, figure_caption types
// Supports chapter-based numbering like "2.1", "3.2" (resets per chapter)
// Extracts number from: caption_number property OR text like "图2.1 xxx" / "表3.1 xxx"
rule "Check figure and table numbering continuity"
when
    $data: ParsedData()
then
    // chapter -> expected sequential number within that chapter
    java.util.Map<Integer, Integer> chapterExpected = new java.util.LinkedHashMap<>();
    java.util.regex.Pattern chapterDotPattern = java.util.regex.Pattern.compile("^(\\d+)\\.(\\d+)$");
    java.util.regex.Pattern figNumPattern = java.util.regex.Pattern.compile("(?:\u56fe|\u8868|Figure|Table)\\s*(\\d+)\\.(\\d+)");
    java.util.regex.Pattern figNumSimple = java.util.regex.Pattern.compile("(?:\u56fe|\u8868|Figure|Table)\\s*(\\d+)(?![\\.\\d])");
    for (Section section : $data.getSectionsList()) {
        String sType = section.getType();
        if ("image".equals(sType) || "figure".equals(sType) || "table".equals(sType) || "figure_caption".equals(sType)) {
            String captionNumStr = (String)section.getPropsMap().get("caption_number");
            int chapterNum = -1;
            int seqNum = -1;
            // Try chapter.seq format first (e.g. "2.1")
            if (captionNumStr != null && !captionNumStr.isEmpty()) {
                java.util.regex.Matcher cm = chapterDotPattern.matcher(captionNumStr.trim());
                if (cm.matches()) {
                    try {
                        chapterNum = Integer.parseInt(cm.group(1));
                        seqNum = Integer.parseInt(cm.group(2));
                    } catch (NumberFormatException e) {}
                } else {
                    // Plain number
                    try { seqNum = Integer.parseInt(captionNumStr.trim()); chapterNum = 0; } catch (NumberFormatException e) {}
                }
            }
            // Fallback: extract from text
            if (seqNum < 0 && section.getText() != null) {
                java.util.regex.Matcher m = figNumPattern.matcher(section.getText());
                if (m.find()) {
                    try { chapterNum = Integer.parseInt(m.group(1)); seqNum = Integer.parseInt(m.group(2)); } catch (NumberFormatException e) {}
                }
                if (seqNum < 0) {
                    java.util.regex.Matcher m2 = figNumSimple.matcher(section.getText());
                    if (m2.find()) {
                        try { seqNum = Integer.parseInt(m2.group(1)); chapterNum = 0; } catch (NumberFormatException e) {}
                    }
                }
            }
            if (seqNum > 0) {
                int expected = chapterExpected.getOrDefault(chapterNum, 1);
                if (seqNum != expected) {
                    String label = chapterNum >= 0 ? chapterNum + "." + seqNum : String.valueOf(seqNum);
                    Issue issue = Issue.newBuilder()
                        .setCode("ERR_INT_CHART_NUM_001")
                        .setMessage("Figure/table numbering not continuous in chapter " + chapterNum + ": expected " + chapterNum + "." + expected + " but got " + label)
                        .setSectionId(section.getSectionId())
                        .setSeverity(Severity.MEDIUM)
                        .setSuggestion("请在每一章内按顺序重新编号图表")
                        .setOriginalSnippet(section.getText() != null ? section.getText() : "")
                        .build();
                    results.add(issue);
                    Issue issue2 = Issue.newBuilder()
                        .setCode("ERR_INT_FIGURE_NUM_SKIP")
                        .setMessage("Figure/table numbering not continuous in chapter " + chapterNum + ": expected " + chapterNum + "." + expected + " but got " + label)
                        .setSectionId(section.getSectionId())
                        .setSeverity(Severity.MEDIUM)
                        .setSuggestion("请在每一章内按顺序重新编号图表")
                        .setOriginalSnippet(section.getText() != null ? section.getText() : "")
                        .build();
                    results.add(issue2);
                }
                chapterExpected.put(chapterNum, seqNum + 1);
            }
        }
    }
    logger.debug("Figure and table numbering continuity check completed");
end
// Rule 5: Check document structure integrity -> ERR_INT_STRUCT_001
rule "Check document structure integrity"
when
    $data: ParsedData()
then
    boolean hasHeading = false;
    for (Section section : $data.getSectionsList()) {
        if ("heading".equals(section.getType())) {
            hasHeading = true;
            break;
        }
    }
    if (!hasHeading) {
        Issue issue = createIntegrityIssue(
            "ERR_INT_STRUCT_001",
            "Document has no heading sections, structure integrity check failed",
            0,
            "请在文档中补充规范的标题层级",
            ""
        );
        results.add(issue);
    }
    logger.debug("Document structure integrity check completed");
end
// Rule 6: Check empty data -> ERR_INT_EMPTY_DATA
rule "Check empty data"
when
    $data: ParsedData(sectionsCount == 0)
then
    results.add(createErrorIssue(
        "ERR_INT_EMPTY_DATA",
        "Input data is empty or has no sections",
        0,
        Severity.MEDIUM
    ));
    logger.warn("Integrity check: input data is empty or has no sections");
end
// Rule 7: Check duplicate sections -> ERR_INT_DUPLICATE_001
rule "Check duplicate sections"
when
    $data: ParsedData()
then
    Set<Integer> seenSectionIds = new HashSet<>();
    for (Section section : $data.getSectionsList()) {
        int sectionId = section.getSectionId();
        if (seenSectionIds.contains(sectionId)) {
            Issue issue = createIntegrityIssue(
                "ERR_INT_DUPLICATE_001",
                "Duplicate section number found: " + sectionId,
                sectionId,
                "Modify section number to avoid duplication",
                section.getText()
            );
            results.add(issue);
        } else {
            seenSectionIds.add(sectionId);
        }
    }
    logger.debug("Duplicate sections check completed");
end
// Rule 8: Check section title format -> ERR_INT_HEADING_FORMAT_001 / 002
rule "Check section title format"
when
    $section: Section(type == "heading")
then
    String text = $section.getText() != null ? $section.getText().trim() : "";
    // Check if starts with a number or Chinese numeral
    if (!text.matches("^\\d+.*") && !text.matches("^[\u4e00\u4e8c\u4e09\u56db\u4e94\u516d\u4e03\u516b\u4e5d\u5341]+[\u3001\u7ae0\u8282].*")) {
        Issue issue = createIntegrityIssue(
            "ERR_INT_HEADING_FORMAT_001",
            "Section title format is not standard: should start with a number or Chinese numeral",
            $section.getSectionId(),
            "Modify title format, e.g. '1. Section Title' or '\u7b2c\u4e00\u7ae0 Section Title'",
            text
        );
        results.add(issue);
    }
    // Check title length (< 3 chars is too short)
    if (text.length() < 3) {
        Issue issue = createIntegrityIssue(
            "ERR_INT_HEADING_FORMAT_002",
            "Section title is too short (< 3 chars): title should accurately describe content",
            $section.getSectionId(),
            "Improve section title",
            text
        );
        results.add(issue);
    }
    // Check title ends with period/full-stop (common formatting error)
    if (text.matches(".*[.\u3002]$")) {
        Issue issue = createIntegrityIssue(
            "ERR_INT_HEADING_FORMAT_002",
            "Section title ends with a period/full-stop, which is not allowed: " + text,
            $section.getSectionId(),
            "Remove the trailing period from the section title",
            text
        );
        results.add(issue);
    }
end
// Rule 9: Check paragraph format in body text -> ERR_INT_PARAGRAPH_FORMAT_001 / 002
// Reads first_line_indent property: "0" means no indent (error), ">= 1" means correct
rule "Check paragraph format in body text"
when
    $section: Section(type == "paragraph", text != null)
then
    String text = $section.getText().trim();
    if (text.length() == 0) {
        // Skip empty paragraphs
    } else {
        // Check first_line_indent property
        String indent = (String)$section.getPropsMap().getOrDefault("first_line_indent",
            (String)$section.getPropsMap().get("first-line-indent"));
        if (indent != null && !indent.isEmpty()) {
            try {
                double indentValue = Double.parseDouble(indent.trim());
                if (indentValue < 1) {
                    Issue issue = createIntegrityIssue(
                        "ERR_INT_PARAGRAPH_FORMAT_001",
                        "Body paragraph missing first-line indentation (first_line_indent=" + indent + ")",
                        $section.getSectionId(),
                        "Set first_line_indent to 2 characters",
                        text.length() > 50 ? text.substring(0, 50) + "..." : text
                    );
                    results.add(issue);
                }
            } catch (NumberFormatException e) {
                logger.warn("Unable to parse first_line_indent: {}", indent);
            }
        }
        // Check paragraph length
        if (text.length() < 20) {
            Issue issue = createIntegrityIssue(
                "ERR_INT_PARAGRAPH_FORMAT_002",
                "Body paragraph is too short, content may be incomplete",
                $section.getSectionId(),
                "请为该段落补充更多内容",
                text
            );
            results.add(issue);
        }
    }
end
// Rule 10: Check logical order between sections -> HIER_INT_ORDER_001
// Design note:
//   HIER_INT_HEADING_STRUCT_001 (Rule 2) already catches heading level jumps using lastLevel tracking.
//   HIER_INT_ORDER_001 is intentionally kept as a SEPARATE, COMPLEMENTARY rule that uses
//   lastLevel tracking (not adjacent-only) to catch the same physical error from the
//   "logical ordering" perspective. Both codes are valid and expected to fire together.
//   The ground-truth for test cases with heading jumps includes BOTH codes.
rule "Check logical order between sections"
when
    $data: ParsedData(sectionsCount > 1)
then
    List<Section> sections = new ArrayList<>($data.getSectionsList());
    // Use lastLevel (not adjacent-only) so paragraphs between headings don't hide jumps
    int lastLevel = 0;
    for (Section section : sections) {
        if ("heading".equals(section.getType())) {
            int currentLevel = section.getLevel();
            if (lastLevel > 0 && currentLevel > lastLevel + 1) {
                Issue issue = createIntegrityIssue(
                    "HIER_INT_ORDER_001",
                    "Heading level jump too large: from level " + lastLevel + " to level " + currentLevel,
                    section.getSectionId(),
                    "Adjust heading levels to change stepwise",
                    section.getText()
                );
                results.add(issue);
            }
            lastLevel = currentLevel;
        }
    }
    logger.debug("Section logical order check completed");
end
// Rule 11: Check association between figures/tables/images and body text -> ERR_INT_CHART_REF_001
// Checks if image/figure sections have corresponding references like "见图N" in body text
rule "Check association between figures/tables and body text"
when
    $data: ParsedData()
then
    for (Section section : $data.getSectionsList()) {
        String sType = section.getType();
        if ("image".equals(sType) || "figure".equals(sType) || "table".equals(sType)) {
            String captionNum = (String)section.getPropsMap().get("caption_number");
            boolean mentioned = false;
            for (Section textSection : $data.getSectionsList()) {
                if ("paragraph".equals(textSection.getType())) {
                    String bodyText = textSection.getText();
                    if (bodyText != null) {
                        // Check for references like "见图1", "图1", "见表1", "table 1", "figure 1"
                        if (captionNum != null && !captionNum.isEmpty()) {
                            // Support both plain "图1" and chapter-based "图2.1" formats
                            String capTrimmed = captionNum.trim();
                            if (bodyText.contains("\u56fe" + capTrimmed) ||
                                bodyText.contains("\u8868" + capTrimmed) ||
                                bodyText.toLowerCase().contains("figure " + capTrimmed) ||
                                bodyText.toLowerCase().contains("table " + capTrimmed) ||
                                bodyText.toLowerCase().contains("figure" + capTrimmed) ||
                                bodyText.toLowerCase().contains("table" + capTrimmed)) {
                                mentioned = true;
                                break;
                            }
                        } else {
                            // No caption_number, check generic references
                            if (bodyText.contains("\u56fe") || bodyText.contains("\u8868") ||
                                bodyText.toLowerCase().contains("figure") ||
                                bodyText.toLowerCase().contains("table")) {
                                mentioned = true;
                                break;
                            }
                        }
                    }
                }
            }
            if (!mentioned) {
                Issue issue = createIntegrityIssue(
                    "ERR_INT_CHART_REF_001",
                    "Figure/table not referenced in body text: " + section.getText().substring(0, Math.min(30, section.getText().length())),
                    section.getSectionId(),
                    "请在正文中引用对应的图表",
                    section.getText()
                );
                results.add(issue);
            }
        }
    }
    logger.debug("Figure/table and body text association check completed");
end

// Rule 11: Thesis Acknowledgement Section Check -> ERR_INT_MISSING_ACKNOWLEDGEMENT (CRITICAL)
// Academic theses (学位论文) MUST contain an acknowledgement section (致谢).
// Detection: fuzzy-match section text for "致谢" / "acknowledgement" / "acknowledgment".
// Only triggered when document type is "thesis" (inferred from metadata title or doc_type field).
rule "Check thesis acknowledgement section"
when
    $data: ParsedData()
then
    // Determine if this is a thesis document
    boolean isThesis = false;
    if ($data.hasMetadata()) {
        String title = $data.getMetadata().getTitle();
        if (!isThesis && title != null) {
            String lowerTitle = title.toLowerCase();
            isThesis = lowerTitle.contains("\u5b66\u4f4d\u8bba\u6587") || lowerTitle.contains("thesis") || lowerTitle.contains("dissertation");
        }
    }
    if (isThesis) {
        boolean hasAcknowledgement = false;
        for (Section section : $data.getSectionsList()) {
            String text = section.getText();
            if (text != null) {
                String lower = text.toLowerCase();
                if (lower.contains("\u81f4\u8c22") || lower.contains("acknowledgement") || lower.contains("acknowledgment")) {
                    hasAcknowledgement = true;
                    break;
                }
            }
        }
        if (!hasAcknowledgement) {
            results.add(Issue.newBuilder()
                .setCode("ERR_INT_MISSING_ACKNOWLEDGEMENT")
                .setMessage("Thesis is missing required acknowledgement section (\u81f4\u8c22)")
                .setSectionId(0)
                .setSeverity(Severity.CRITICAL)
                .setSuggestion("请在论文中补充致谢部分（致谢）")
                .setOriginalSnippet("")
                .build());
        }
        logger.debug("Thesis acknowledgement check completed, found: {}", hasAcknowledgement);
    }
end
