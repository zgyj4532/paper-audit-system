<?xml version="1.0" encoding="UTF-8"?>
<kmodule xmlns="http://www.drools.org/xsd/kmodule">
    <!-- 排版规则库 -->
    <kbase name="formattingRules" packages="rules.formatting" default="false">
        <ksession name="formattingSession" default="false" />
    </kbase>

    <!-- 引用检查规则库 -->
    <kbase name="referenceRules" packages="rules.reference" default="false">
        <ksession name="referenceSession" default="false" />
    </kbase>

    <!-- 完整性规则库 -->
    <kbase name="integrityRules" packages="rules.integrity" default="false">
        <ksession name="integritySession" default="false" />
    </kbase>
</kmodule>
